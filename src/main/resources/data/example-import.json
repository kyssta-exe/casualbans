    "name": "Optional. Player name (resolved from UUID if omitted).",
    "ip": "Optional. IP address for IP bans.",
    "reason": "Optional. Default: 'Imported'.",
    "executorUUID": "Optional. Staff UUID. Default: console UUID.",
    "executorName": "Optional. Staff name. Default: 'Console'.",
    "dateStart": "Optional. Unix epoch millis. Default: now.",
    "dateEnd": "Optional. Unix epoch millis. 0 = permanent.",
    "duration": "Optional. Duration in millis. Derived from dateEnd-dateStart if omitted.",
    "serverScope": "Optional. Server scope. Default: plugin default.",
    "serverOrigin": "Optional. Server origin. Default: current server.",
    "silent": "Optional. Boolean. Default: false.",
    "ipPunish": "Optional. Boolean. Auto-set for IPBAN/IPMUTE types.",
    "active": "Optional. Boolean. Derived from expiry if omitted."
  },
